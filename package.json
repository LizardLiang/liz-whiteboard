{
  "name": "liz-whiteboard",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite dev --host 0.0.0.0 --port 3000\" \"dotenv -e .env.local -- bun run server.dev.ts\"",
    "dev:server": "dotenv -e .env.local -- bun run server.dev.ts",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint",
    "format": "prettier",
    "typecheck": "tsc --noEmit",
    "check": "prettier --write . && eslint --fix && bun run typecheck",
    "post-cta-init": "npx create-db@latest",
    "db:seed": "dotenv -e .env.local -- bun seed.ts",
    "docker:build": "docker build -t liz-whiteboard:test .",
    "docker:run": "docker run --rm -p 3000:3000 liz-whiteboard:test",
    "prepare": "bunx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-push": "bun run typecheck"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-form": "^1.0.0",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.10",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/d3-force": "^3.0.10",
    "@xyflow/react": "^12.9.2",
    "bcryptjs": "^3.0.3",
    "chevrotain": "^11.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-force": "^3.0.0",
    "elkjs": "0.10.0",
    "html-to-image": "^1.11.13",
    "jose": "6.2.3",
    "lucide-react": "^0.544.0",
    "next-themes": "^0.4.6",
    "nitro": "^3.0.260311-beta",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.6",
    "tw-animate-css": "^1.3.6",
    "use-debounce": "^10.1.1",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tanstack/eslint-config": "^0.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "axe-core": "^4.11.2",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.5.3",
    "shadcn": "^3.5.0",
    "simple-git-hooks": "^2.13.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^4.0.4",
    "web-vitals": "^5.1.0"
  }
}
